@page
@model DivCode.Pages.AboutMeModel
@{

    ViewData["Title"] = "About Me";
}


<div class="about-page">
    <div class="about-container">
        <div class="about-photo">
            <img src="~/files/whatsapp image 2026-01-18 at 18.03.13.jpeg" lt="Divine Ilunga" />

        </div>

        <div class="about-text">
            <h1>About Me</h1>
            <p>
                Hello! I’m <strong>Divine Ngalula Ilunga</strong>, a third-year software development student
                passionate about turning ideas into clean, functional, and user-friendly applications.
            </p>
            <p>
                I enjoy working across web, mobile, and backend platforms, exploring technologies like
                C#, .NET, Python, Kotlin, Swift, and React. Every project is an opportunity to solve
                real problems while learning new skills.
            </p>
            <p>
                When I’m not coding, I love designing visually appealing interfaces, experimenting with
                pastel color palettes, and adding playful but professional touches to my work.
            </p>
            <div class="skills">
                <span>C#</span>
                <span>.NET</span>
                <span>SQL</span>
                <span>Python</span>
                <span>Kotlin</span>
                <span>JS</span>
            </div>
        </div>
    </div
       </div>

